{
  "name": "@ralph-rlm/engine",
  "version": "0.2.0",
  "description": "Ralph RLM loop engine — verify, rollover, OpenCode SDK worker lifecycle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doeixd/opencode-ralph-rlm",
    "directory": "packages/engine"
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "type": "module",
